    def group_and_aggregate(self, groupby_column, agg_dict=None):
        """
        Group data by a column and apply aggregation functions.
        
        Args:
            groupby_column (str or list): Column(s) to group by
            agg_dict (dict): Dictionary with column names as keys and aggregation functions as values
        
        Returns:
            pd.DataFrame: Grouped and aggregated DataFrame
        """
        if agg_dict is None:
            agg_dict = {}
        
        if len(agg_dict) == 0:
            print("No aggregation functions provided. Using count()...")
            grouped = self.df.groupby(groupby_column).size(14)
        else:
            grouped = self.df.groupby(groupby_column).agg(agg_dict)
        
        print(f"Grouped by '{groupby_column}':")
        print(grouped)
        return grouped
    
    def conditional_cleaning(self, column, condition_func, action_func):
        """
        Apply conditional cleaning based on user-defined conditions.
        
        Args:
            column (str): Column to apply condition to
            condition_func (callable): Function that returns boolean mask
            action_func (callable): Function to apply to filtered rows
        """
        mask = condition_func(self.df[column])
        affected_rows = mask.sum()
        
        if affected_rows > 0:
            print(f"Applying action to {affected_rows} rows in '{column}'")
            self.df.loc[mask, column] = self.df.loc[mask, column].apply(action_func)
            self.cleaning_log.append(f"Applied conditional action to {affected_rows} rows in {column}")
        else:
            print(f"No rows matched the condition for '{column}'")
    
    def data_type_conversion(self, column, target_type):
        """
        Convert column data type with error handling.
        
        Args:
            column (str): Column name to convert
            target_type (str): Target data type ('int', 'float', 'str', 'datetime')
        """
        try:
            if target_type == 'int':
                self.df[column] = self.df[column].astype('int64')
            elif target_type == 'float':
                self.df[column] = self.df[column].astype('float64')
            elif target_type == 'str':
                self.df[column] = self.df[column].astype('str')
            elif target_type == 'datetime':
                self.df[column] = pd.to_datetime(self.df[column])
            else:
                print(f"Unknown target type: {target_type}")
                return
            
            print(f"Successfully converted '{column}' to {target_type}")
            self.cleaning_log.append(f"Converted {column} to {target_type}")
        except Exception as e:
            print(f"Error converting '{column}' to {target_type}: {str(e)}")
            self.cleaning_log.append(f"FAILED: Conversion of {column} to {target_type}")
    
    def get_cleaning_summary(self):
